{
  "installCommand": "pnpm --dir artifacts/south-point-school install --ignore-workspace",
  "buildCommand": "pnpm --dir artifacts/south-point-school run build",
  "outputDirectory": "artifacts/south-point-school/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
